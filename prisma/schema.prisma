datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(uuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String? // es opcional porque los de Google no tienen contraseña
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cartItems     CartItem[]
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int // Cambiado a Int (o String, según uses en tu BD para los productos)
  createdAt DateTime @default(now())

  // Esto crea una clave compuesta para que un usuario no pueda 
  // agregar el mismo producto dos veces a su lista
  @@unique([userId, productId])
}

// 🛒 NUEVO MODELO: Para guardar los carritos persistidos en Aiven
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int // Uso Int porque GraphQL expone los IDs como Int
  title     String
  price     Float
  quantity  Int
  image     String
  size      String // Esencial para diferenciar si agregaron talle 39 o 42
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, size]) // 👈 CANDADO: Evita duplicados a nivel de base de datos
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          Int              @id
  name        String
  description String           @db.Text
  price       Float
  category    String
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id        String         @id @default(uuid())
  colorName String
  productId Int
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade) // 🌟 Corregido: [id]
  skus      ProductSku[]
  images    VariantImage[]
}

model VariantImage {
  id        String         @id @default(uuid())
  url       String
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade) // 🌟 Corregido: [id]
}

model ProductSku {
  id        String         @id @default(uuid())
  articleId Int            @unique
  size      String
  stock     Int            @default(10)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade) // 🌟 Corregido: [id]
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  total     Float
  status    String // "PENDING", "PAID", "EXPIRED"
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  expiresAt DateTime
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

// 🛒 items comprados, es el historial
model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  title     String
  price     Float
  quantity  Int
  size      String
  image     String
}

model OrderOrReservation {
  id        String   @id @default(uuid())
  userId    String
  productId Int
  size      String
  quantity  Int
  status    String // "PENDING_PAYMENT", "PAID", "EXPIRED"
  createdAt DateTime @default(now())
  expiresAt DateTime // 🌟 La clave: createdAt + 10 minutos
}
